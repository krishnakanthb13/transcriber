# Obtain the API key form https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Which model to use whisper-large-v3 / whisper-large-v3-turbo
TRANSCRIBER_MODEL=whisper-large-v3

# Maximum file size (MB) before chunking kicks in
TRANSCRIBER_MAX_UPLOAD_MB=25

# Chunk duration in seconds for large files
TRANSCRIBER_CHUNK_DURATION_SECONDS=600

# Overlap in seconds to maintain context between chunks
TRANSCRIBER_CHUNK_OVERLAP_SECONDS=5

# Max retries for failed chunk API transcription calls
TRANSCRIBER_MAX_RETRIES=3

# Set to "OFF" to disable file logging
TRANSCRIBER_LOG_FILE=logs/transcriber.log
# Set TRANSCRIBER_LOG_FILE=OFF to disable the logs folder
